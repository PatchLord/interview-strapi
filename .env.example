# Copy this to `.env` (`cp .env.example .env`) then run `bun install && bun run develop`.
# Defaults to SQLite so there is NOTHING else to install. Throwaway dev secrets — fine for local use.

HOST=0.0.0.0
PORT=1337

# Dev-only secrets (throwaway — this is a local demo CMS with fake data)
APP_KEYS=devkey1AAAAAAAAAAAAAAAAA==,devkey2AAAAAAAAAAAAAAAAA==,devkey3AAAAAAAAAAAAAAAAA==,devkey4AAAAAAAAAAAAAAAAA==
API_TOKEN_SALT=devApiTokenSaltAAAAAAAAAA==
ADMIN_JWT_SECRET=devAdminJwtSecretAAAAAAAA==
JWT_SECRET=devJwtSecretAAAAAAAAAAAAAA==
TRANSFER_TOKEN_SALT=devTransferTokenSaltAAAAA==
ENCRYPTION_KEY=devEncryptionKeyAAAAAAAAA==

# Database — SQLite by default (no external DB needed)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# To use Postgres instead, set DATABASE_CLIENT=postgres and fill these:
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_NAME=interview_strapi
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=admin
